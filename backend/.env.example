ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
# Optional: gpt-4o-mini-realtime-preview-2024-12-17
OPENAI_REALTIME_MODEL=gpt-4o-mini-realtime-preview-2024-12-17
OPENAI_REALTIME_VOICE=alloy
# “You” captions (separate ASR; Bistro still hears raw audio): gpt-4o-mini-transcribe | gpt-4o-transcribe
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
PORT=3000
